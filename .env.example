# EmailJS Environment Variables
# Sign up at https://www.emailjs.com/ (free tier: 200 emails/month)
#
# Steps:
# 1. Create an account at emailjs.com
# 2. Add an Email Service (Gmail, Outlook, etc.) → get SERVICE_ID
# 3. Create an Email Template → get TEMPLATE_ID
#    Template variables: {{from_name}}, {{from_email}}, {{message}}
# 4. Go to Account → API Keys → get PUBLIC_KEY
#
# Copy this file to .env and fill in the values:

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# WhatsApp number (country code + number, no +, no spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=917420008485
